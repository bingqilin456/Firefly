---
import { url } from "@/utils/url-utils";

const imagePath = "/assets/images/sponsor/qq-link.jpg";
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QQ</title>
    <style is:inline>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        width: 100%;
        height: 100%;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      @media (prefers-color-scheme: dark) {
        html, body { background: #1a1a1a; }
      }
      img {
        max-width: min(400px, 90vw);
        max-height: 90vh;
        width: auto;
        height: auto;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.12);
      }
    </style>
  </head>
  <body>
    <img src={url(imagePath)} alt="QQ" />
  </body>
</html>
